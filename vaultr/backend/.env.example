DATABASE_URL="postgresql://user:password@host:5432/vaultr?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
CLAUDE_API_KEY="sk-ant-..."
PORT=4000

# Email delivery for verification codes (optional).
# If SMTP_HOST/SMTP_USER/SMTP_PASS are unset, the app runs in dev mode and logs
# the code to the server console instead of sending mail — the flow still works
# locally. Set them to send real email via SMTP (Gmail, Mailtrap, Postmark, etc.).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
EMAIL_FROM="Vaultr <no-reply@vaultr.app>"
