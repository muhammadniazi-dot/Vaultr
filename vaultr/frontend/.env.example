# API base URL the mobile app talks to.
#
# - Web preview / iOS simulator on this machine: http://localhost:4000
# - Physical phone in Expo Go: use this machine's LAN IP (e.g. http://192.168.1.42:4000)
#   and make sure the phone is on the same Wi-Fi. Find your IP with `ipconfig`
#   (Windows) or `ifconfig` (macOS/Linux). Restart `expo start` after changing.
EXPO_PUBLIC_API_URL=http://localhost:4000
