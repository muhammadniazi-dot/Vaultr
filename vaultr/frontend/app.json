{
  "expo": {
    "name": "Vaultr",
    "slug": "vaultr",
    "scheme": "vaultr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f0f0f",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/brandmark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vaultr.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Vaultr uses Face ID to securely unlock your account."
      }
    },
    "android": {
      "package": "com.vaultr.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brandmark.png",
        "backgroundColor": "#0f0f0f"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-asset",
      "expo-font"
    ]
  }
}
